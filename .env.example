# Copy to .env.local for local dev, or set in Vercel / VPS dashboard for production.

# Your live site URL (required for SEO / Open Graph)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional — Supabase CMS (leave unset to use built-in fallbacks)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Optional — contact form (EmailJS)
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
